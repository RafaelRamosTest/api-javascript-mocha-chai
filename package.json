{
  "name": "api-automation-challenge",
  "version": "1.0.0",
  "description": "Desafio de Automação de Testes de API - JavaScript + Mocha + Chai",
  "main": "index.js",
  "scripts": {
    "test": "mocha test/**/*.spec.js --timeout 10000 --exit",
    "test:report": "mocha test/**/*.spec.js --reporter mochawesome --reporter-options reportDir=mochawesome-report,reportFilename=index,html=true,json=true --timeout 10000 --exit",
    "test:allure": "mocha \"test/**/*.spec.js\" --require utils/mocha-setup.js --reporter mocha-multi-reporters --reporter-options configFile=reporter-config.json || true",
    "ci:test": "start-server-and-test 'npx serverest start --port 3000 > serverest.log 2>&1' http://localhost:3000 'npm run test:allure'"
  },
  "keywords": [
    "mocha",
    "chai",
    "supertest",
    "api",
    "automation",
    "serverest"
  ],
  "author": "QA Engineer",
  "license": "MIT",
  "devDependencies": {
    "allure-mocha": "^3.10.2",
    "chai": "^4.3.7",
    "chai-json-schema": "^1.5.1",
    "mocha": "^10.2.0",
    "mocha-multi-reporters": "^1.5.1",
    "mochawesome": "^7.1.3",
    "start-server-and-test": "^3.0.11",
    "supertest": "^6.3.3"
  }
}
